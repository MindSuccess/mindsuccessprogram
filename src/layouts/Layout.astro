---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object;
}

const { title, description, canonical, ogImage = 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1200', schema } = Astro.props;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta name='impact-site-verification' value='2b68d695-6109-4314-9b11-1a6905180e3a' />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mind Success Program" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logos/logo-final.png" />

    <!-- Schema -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <!-- Website Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Mind Success Program",
      "url": "https://mindsuccessprogram.com",
      "description": "Discover the world's most powerful mindset programs, tools, and techniques to rewire your brain for extraordinary success.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://mindsuccessprogram.com/blog/?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
    </script>
  </head>
  <body>
    <!-- Affiliate Disclosure Banner -->
    <div class="bg-[#1A1A2E] border-b border-[#D4AF37]/20 py-2 px-4 text-center">
      <p class="text-gray-400 text-xs">
        <strong class="text-[#D4AF37]">Affiliate Disclosure:</strong> Mind Success Program earns commissions from qualifying purchases made through links on this site, at no extra cost to you. <a href="/about/" class="text-[#D4AF37] hover:underline">Learn more</a>.
      </p>
    </div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Mobile menu toggle
      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobile-menu');
      if (hamburger && mobileMenu) {
        hamburger.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });
      }
    </script>
  </body>
</html>
