---
const year = new Date().getFullYear();
---

<footer class="bg-[#0A0A14] border-t border-[#D4AF37]/20 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-4">
          <img src="/logos/logo-option-1.svg" alt="Mind Success Program" class="h-12 w-12" />
          <span class="font-bold text-xl text-white" style="font-family:'Poppins',sans-serif;">
            Mind<span class="text-[#D4AF37]">Success</span><br/><span class="text-sm font-normal text-gray-400">Program</span>
          </span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed">
          Your trusted guide to the world's best mindset programs, mental performance tools, and personal development resources.
        </p>
        <p class="text-gray-500 text-xs mt-4">
          <strong class="text-gray-400">Affiliate Disclosure:</strong> Mind Success Program participates in affiliate marketing programs. We earn a commission when you purchase through our links, at no extra cost to you. We only recommend products we genuinely believe in.
        </p>
      </div>

      <!-- Pages -->
      <div>
        <h4 class="text-white font-semibold mb-4" style="font-family:'Poppins',sans-serif;">Explore</h4>
        <ul class="space-y-2">
          <li><a href="/mindset-training/" class="text-gray-400 hover:text-[#D4AF37] text-sm transition-colors">Mindset Training</a></li>
          <li><a href="/success-habits/" class="text-gray-400 hover:text-[#D4AF37] text-sm transition-colors">Success Habits</a></li>
          <li><a href="/mind-reprogramming/" class="text-gray-400 hover:text-[#D4AF37] text-sm transition-colors">Mind Reprogramming</a></li>
          <li><a href="/resources/" class="text-gray-400 hover:text-[#D4AF37] text-sm transition-colors">Resources</a></li>
          <li><a href="/about/" class="text-gray-400 hover:text-[#D4AF37] text-sm transition-colors">About Us</a></li>
          <li><a href="/contact/" class="text-gray-400 hover:text-[#D4AF37] text-sm transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Reviews -->
      <div>
        <h4 class="text-white font-semibold mb-4" style="font-family:'Poppins',sans-serif;">Reviews</h4>
        <ul class="space-y-2">
          <li><a href="/reviews/" class="text-gray-400 hover:text-[#D4AF37] text-sm transition-colors">All Reviews</a></li>
          <li><a href="/reviews/mindvalley-review/" class="text-gray-400 hover:text-[#D4AF37] text-sm transition-colors">Mindvalley Review</a></li>
          <li><a href="/reviews/neurogym-review/" class="text-gray-400 hover:text-[#D4AF37] text-sm transition-colors">NeuroGym Review</a></li>
          <li><a href="/reviews/best-mindset-programs/" class="text-gray-400 hover:text-[#D4AF37] text-sm transition-colors">Best Programs 2024</a></li>
        </ul>
      </div>

      <!-- Blog -->
      <div>
        <h4 class="text-white font-semibold mb-4" style="font-family:'Poppins',sans-serif;">Latest Articles</h4>
        <ul class="space-y-2">
          <li><a href="/blog/how-to-reprogram-your-mind-for-success/" class="text-gray-400 hover:text-[#D4AF37] text-sm transition-colors">Reprogram Your Mind</a></li>
          <li><a href="/blog/best-morning-routine-for-success/" class="text-gray-400 hover:text-[#D4AF37] text-sm transition-colors">Best Morning Routine</a></li>
          <li><a href="/blog/mindvalley-vs-masterclass/" class="text-gray-400 hover:text-[#D4AF37] text-sm transition-colors">Mindvalley vs MasterClass</a></li>
          <li><a href="/blog/subconscious-mind-techniques/" class="text-gray-400 hover:text-[#D4AF37] text-sm transition-colors">Subconscious Techniques</a></li>
          <li><a href="/blog/growth-mindset-vs-fixed-mindset/" class="text-gray-400 hover:text-[#D4AF37] text-sm transition-colors">Growth vs Fixed Mindset</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-[#D4AF37]/10 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-sm">
        &copy; {year} Mind Success Program. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="/privacy-policy/" class="text-gray-500 hover:text-[#D4AF37] text-sm transition-colors">Privacy Policy</a>
        <a href="/terms-of-use/" class="text-gray-500 hover:text-[#D4AF37] text-sm transition-colors">Terms of Use</a>
        <a href="/affiliate-disclosure/" class="text-gray-500 hover:text-[#D4AF37] text-sm transition-colors">Affiliate Disclosure</a>
        <a href="/sitemap.xml" class="text-gray-500 hover:text-[#D4AF37] text-sm transition-colors">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
