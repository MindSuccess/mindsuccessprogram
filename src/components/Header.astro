---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/mindset-training/', label: 'Mindset Training' },
  { href: '/success-habits/', label: 'Success Habits' },
  { href: '/reviews/', label: 'Reviews' },
  { href: '/blog/', label: 'Blog' },
  { href: '/resources/', label: 'Resources' },
];
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-[#0D0D1A]/95 backdrop-blur-md border-b border-[#D4AF37]/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <img src="/logos/logo-final.png" alt="Mind Success Program" class="h-10 w-10" />
        <span class="font-bold text-lg text-white hidden sm:block" style="font-family:'Poppins',sans-serif;">
          Mind<span class="text-[#D4AF37]">Success</span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`nav-link text-sm ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'text-[#D4AF37]' : ''}`}
          >
            {link.label}
          </a>
        ))}
        <a href="/reviews/" class="btn-gold text-sm py-2 px-4">Start Free →</a>
      </nav>

      <!-- Mobile Hamburger -->
      <button id="hamburger" class="md:hidden text-white p-2" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <nav class="flex flex-col gap-3">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`nav-link py-2 border-b border-[#D4AF37]/10 ${currentPath === link.href ? 'text-[#D4AF37]' : ''}`}
          >
            {link.label}
          </a>
        ))}
        <a href="/reviews/" class="btn-gold text-center mt-2">Start Free →</a>
      </nav>
    </div>
  </div>
</header>
