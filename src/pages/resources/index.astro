---
import Layout from '../../layouts/Layout.astro';

const resources = [
  {
    category: "Recommended Books",
    icon: "📚",
    items: [
      { name: "Atomic Habits by James Clear", description: "The definitive guide to building good habits and breaking bad ones through tiny, incremental changes.", link: "[AMAZON_AFFILIATE_LINK]" },
      { name: "Mindset by Carol S. Dweck", description: "Stanford psychologist's groundbreaking research on how our beliefs about ability shape our success.", link: "[AMAZON_AFFILIATE_LINK]" },
      { name: "The Biology of Belief by Bruce Lipton", description: "How your beliefs directly influence your biology and gene expression.", link: "[AMAZON_AFFILIATE_LINK]" },
      { name: "Thinking, Fast and Slow by Daniel Kahneman", description: "Nobel laureate's exploration of the two systems that drive the way we think.", link: "[AMAZON_AFFILIATE_LINK]" },
      { name: "Breaking the Habit of Being Yourself by Joe Dispenza", description: "How to lose your mind and create a new one through meditation and neuroplasticity.", link: "[AMAZON_AFFILIATE_LINK]" },
      { name: "Psycho-Cybernetics by Maxwell Maltz", description: "The classic guide to self-image psychology and the creative mechanism within us.", link: "[AMAZON_AFFILIATE_LINK]" },
    ]
  },
  {
    category: "Essential Podcasts",
    icon: "🎧",
    items: [
      { name: "The Mindvalley Podcast", description: "Vishen Lakhiani interviews world-class experts on personal growth, health, and consciousness.", link: "[MINDVALLEY_AFFILIATE_LINK]" },
      { name: "The Tony Robbins Podcast", description: "Strategies and insights for business, relationships, health, and wealth.", link: "[CLICKBANK_AFFILIATE_LINK]" },
      { name: "The School of Greatness with Lewis Howes", description: "Interviews with the most successful people in the world about their mindset and habits.", link: "#" },
      { name: "Impact Theory with Tom Bilyeu", description: "Deep interviews exploring the mindsets of the world's highest achievers.", link: "#" },
    ]
  },
  {
    category: "Apps & Tools",
    icon: "📱",
    items: [
      { name: "Headspace", description: "Guided meditation for beginners and advanced practitioners. Excellent for building a daily practice.", link: "[AMAZON_AFFILIATE_LINK]" },
      { name: "Blinkist", description: "15-minute summaries of the world's best books. Perfect for busy achievers.", link: "[BLINKIST_AFFILIATE_LINK]" },
      { name: "Audible", description: "The largest audiobook library. Turn commute time into learning time.", link: "[AUDIBLE_AFFILIATE_LINK]" },
      { name: "Notion", description: "All-in-one workspace for goal tracking, journaling, and life organization.", link: "#" },
      { name: "Calm", description: "Meditation, sleep stories, and breathing exercises. Best-in-class for sleep content.", link: "[AMAZON_AFFILIATE_LINK]" },
    ]
  },
  {
    category: "Free Guides & Downloads",
    icon: "📥",
    items: [
      { name: "7-Day Mind Rewiring Blueprint", description: "Our exclusive step-by-step guide to reprogramming your subconscious in one week.", link: "#" },
      { name: "Morning Routine Checklist", description: "The exact checklist used by top performers to start every day at peak capacity.", link: "#" },
      { name: "Limiting Beliefs Worksheet", description: "A structured worksheet for identifying and dismantling your hidden limiting beliefs.", link: "#" },
      { name: "Goal Setting Framework", description: "The SMART-ER framework for setting goals that actually get achieved.", link: "#" },
    ]
  }
];
---

<Layout
  title="Resources — Best Books, Apps, and Tools for Mindset & Success"
  description="Curated resources for mindset transformation: the best books, podcasts, apps, and free tools to accelerate your personal development journey."
>
  <section class="py-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-[#D4AF37] font-semibold uppercase tracking-widest mb-3 text-sm">Curated Collection</p>
      <h1 class="text-5xl font-black text-white mb-4" style="font-family:'Poppins',sans-serif;">Resources</h1>
      <p class="text-gray-400 max-w-2xl mx-auto text-lg">
        The books, apps, podcasts, and tools we personally use and recommend. Every resource has been tested and vetted.
      </p>
    </div>

    <!-- Affiliate Disclosure -->
    <div class="card-bg rounded-xl p-4 border border-[#D4AF37]/20 mb-10 flex items-start gap-3 max-w-4xl mx-auto">
      <span class="text-[#D4AF37] text-xl mt-0.5">ℹ️</span>
      <p class="text-gray-400 text-sm">
        <strong class="text-gray-300">Affiliate Disclosure:</strong> Mind Success Program participates in affiliate marketing programs including Amazon Associates, Mindvalley, Blinkist, and Audible. We earn a commission when you purchase through our links, at no extra cost to you. We only recommend resources we genuinely use and believe in.
      </p>
    </div>

    {resources.map(section => (
      <div class="mb-16">
        <h2 class="text-2xl font-black text-white mb-6 flex items-center gap-3" style="font-family:'Poppins',sans-serif;">
          <span class="text-3xl">{section.icon}</span>
          {section.category}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {section.items.map(item => (
            <div class="card-bg rounded-xl p-6 border border-[#D4AF37]/10 hover:border-[#D4AF37]/30 transition-all">
              <h3 class="text-white font-bold mb-2" style="font-family:'Poppins',sans-serif;">{item.name}</h3>
              <p class="text-gray-400 text-sm mb-4">{item.description}</p>
              {item.link !== '#' && (
                <a href={item.link} class="text-[#D4AF37] text-sm font-semibold hover:underline" rel="sponsored noopener" target="_blank">
                  Check it out →
                </a>
              )}
              {item.link === '#' && (
                <span class="text-gray-600 text-sm">Coming soon</span>
              )}
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>

  <section class="py-16 bg-[#0A0A14]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-black text-white mb-4" style="font-family:'Poppins',sans-serif;">Want More Resources?</h2>
      <p class="text-gray-400 mb-8">Join our newsletter and get new resources, book recommendations, and exclusive guides delivered to your inbox every week.</p>
      <form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
        <input
          type="email"
          placeholder="Enter your email"
          class="flex-1 px-5 py-4 rounded-lg bg-white/10 border border-white/20 text-white placeholder-gray-400 focus:outline-none focus:border-[#D4AF37] text-sm"
        />
        <button type="submit" class="btn-gold whitespace-nowrap">
          Subscribe →
        </button>
      </form>
    </div>
  </section>
</Layout>
