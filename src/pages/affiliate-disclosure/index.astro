---
import Layout from '../../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Affiliate Disclosure",
  "url": "https://mindsuccessprogram.com/affiliate-disclosure/",
  "description": "Mind Success Program's affiliate disclosure and transparency policy."
};
---

<Layout
  title="Affiliate Disclosure | Mind Success Program"
  description="Mind Success Program participates in affiliate marketing programs. Learn how we earn commissions and how it affects our recommendations."
  schema={schema}
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <header class="mb-10">
      <h1 class="text-4xl md:text-5xl font-black text-white mb-4" style="font-family:'Poppins',sans-serif;">
        Affiliate Disclosure
      </h1>
      <p class="text-gray-400">Last Updated: April 29, 2026</p>
    </header>

    <div class="prose-dark space-y-8">
      <section>
        <h2>Our Commitment to Transparency</h2>
        <p>Mind Success Program is committed to full transparency about how we generate revenue and how that may affect the content you read on our site. This disclosure is provided in accordance with the <strong>Federal Trade Commission (FTC) guidelines</strong> on endorsements and testimonials, as well as the requirements of our affiliate partners.</p>
      </section>

      <section>
        <h2>What Is Affiliate Marketing?</h2>
        <p>Affiliate marketing is a performance-based advertising model where we earn a commission when you click on a link on our website and make a purchase from the merchant. The price you pay is exactly the same whether you use our affiliate link or go directly to the merchant's website. The commission comes out of the merchant's margin, not your pocket.</p>
      </section>

      <section>
        <h2>Our Affiliate Partners</h2>
        <p>We currently participate in the following affiliate programs:</p>
        <ul>
          <li><strong>Mindvalley Affiliate Program</strong> — We earn a commission on Mindvalley All Access memberships and individual program purchases.</li>
          <li><strong>NeuroGym Affiliate Program</strong> — We earn a commission on NeuroGym program and membership purchases.</li>
          <li><strong>Amazon Associates Program</strong> — We earn a commission on qualifying purchases made through Amazon affiliate links (including books and Audible subscriptions).</li>
          <li><strong>Blinkist Affiliate Program</strong> — We earn a commission on Blinkist Premium subscriptions.</li>
          <li><strong>ClickBank Affiliate Network</strong> — We earn commissions on select personal development products.</li>
        </ul>
      </section>

      <section>
        <h2>How We Choose What to Recommend</h2>
        <p>Our recommendations are based on the following criteria, in this order:</p>
        <ol>
          <li><strong>Personal Testing:</strong> We personally use and test every program we recommend for a minimum of 30 days before writing a review.</li>
          <li><strong>Scientific Credibility:</strong> We prioritize programs with legitimate scientific backing and credible instructors.</li>
          <li><strong>Real-World Results:</strong> We evaluate whether the program delivers on its promises for real users.</li>
          <li><strong>Value for Money:</strong> We assess whether the program is worth the investment relative to alternatives.</li>
        </ol>
        <p><strong>We do not recommend products solely because they offer affiliate commissions.</strong> If a program doesn't meet our standards, we simply don't cover it — regardless of how much it pays.</p>
      </section>

      <section>
        <h2>How to Identify Affiliate Links</h2>
        <p>Affiliate links on our site are identified in the following ways:</p>
        <ul>
          <li>They include <code>rel="sponsored"</code> in the HTML</li>
          <li>They open in a new tab (<code>target="_blank"</code>)</li>
          <li>They are accompanied by a disclosure notice on the page</li>
          <li>They may use tracking parameters that identify Mind Success Program as the referrer</li>
        </ul>
      </section>

      <section>
        <h2>Our Promise to You</h2>
        <p>We will always:</p>
        <ul>
          <li>Disclose our affiliate relationships clearly and conspicuously</li>
          <li>Only recommend products we genuinely believe in</li>
          <li>Provide honest reviews that include both pros and cons</li>
          <li>Never let affiliate commissions influence our ratings or recommendations</li>
          <li>Respond to questions about our affiliate relationships honestly</li>
        </ul>
      </section>

      <section>
        <h2>Questions?</h2>
        <p>If you have any questions about our affiliate relationships or how we make money, please <a href="/contact/" class="text-[#D4AF37] hover:underline">contact us</a> or email us directly at <a href="mailto:support@mindsuccessprogram.com" class="text-[#D4AF37] hover:underline">support@mindsuccessprogram.com</a>.</p>
      </section>
    </div>
  </article>
</Layout>
