---
import Layout from '../../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Mind Success Program",
  "url": "https://mindsuccessprogram.com/contact/",
  "description": "Get in touch with the Mind Success Program team. Questions, feedback, partnership inquiries, or just want to say hello? We'd love to hear from you."
};
---

<Layout
  title="Contact Us — Mind Success Program"
  description="Have a question, feedback, or partnership inquiry? Reach out to the Mind Success Program team. We read every message and respond as quickly as possible."
  schema={schema}
>
  <section class="py-20 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-[#D4AF37] font-semibold uppercase tracking-widest mb-3 text-sm">Get In Touch</p>
      <h1 class="text-5xl font-black text-white mb-4" style="font-family:'Poppins',sans-serif;">Contact Us</h1>
      <p class="text-gray-400 max-w-2xl mx-auto text-lg">
        Have a question, feedback, or just want to say hello? We'd love to hear from you. We read every message and respond as quickly as we can.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Contact Info -->
      <div>
        <h2 class="text-2xl font-bold text-white mb-6" style="font-family:'Poppins',sans-serif;">Ways to Reach Us</h2>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-[#D4AF37]/10 flex items-center justify-center text-[#D4AF37] text-lg shrink-0">📧</div>
            <div>
              <h3 class="text-white font-semibold mb-1">Email</h3>
              <p class="text-gray-400 text-sm">support@mindsuccessprogram.com</p>
              <p class="text-gray-500 text-xs mt-1">We typically respond within 24-48 hours.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-[#D4AF37]/10 flex items-center justify-center text-[#D4AF37] text-lg shrink-0">💬</div>
            <div>
              <h3 class="text-white font-semibold mb-1">General Inquiries</h3>
              <p class="text-gray-400 text-sm">Questions about our content, program recommendations, or general feedback.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-[#D4AF37]/10 flex items-center justify-center text-[#D4AF37] text-lg shrink-0">🤝</div>
            <div>
              <h3 class="text-white font-semibold mb-1">Partnerships</h3>
              <p class="text-gray-400 text-sm">Interested in partnering with Mind Success Program? We'd love to explore opportunities.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-[#D4AF37]/10 flex items-center justify-center text-[#D4AF37] text-lg shrink-0">📰</div>
            <div>
              <h3 class="text-white font-semibold mb-1">Media & Press</h3>
              <p class="text-gray-400 text-sm">For media inquiries, interviews, or press-related requests.</p>
            </div>
          </div>
        </div>

        <div class="mt-10 pt-8 border-t border-[#D4AF37]/20">
          <h3 class="text-white font-semibold mb-3">Response Times</h3>
          <ul class="space-y-2 text-gray-400 text-sm">
            <li>General inquiries: 24-48 hours</li>
            <li>Partnership requests: 2-3 business days</li>
            <li>Media inquiries: 1-2 business days</li>
          </ul>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="card-bg rounded-2xl p-8 border border-[#D4AF37]/20">
        <h2 class="text-2xl font-bold text-white mb-6" style="font-family:'Poppins',sans-serif;">Send a Message</h2>
        <form class="space-y-5">
          <div>
            <label for="name" class="block text-gray-300 text-sm font-medium mb-2">Your Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-lg bg-[#0D0D1A] border border-[#D4AF37]/20 text-white placeholder-gray-500 focus:outline-none focus:border-[#D4AF37] text-sm"
              placeholder="John Doe"
            />
          </div>
          <div>
            <label for="email" class="block text-gray-300 text-sm font-medium mb-2">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-lg bg-[#0D0D1A] border border-[#D4AF37]/20 text-white placeholder-gray-500 focus:outline-none focus:border-[#D4AF37] text-sm"
              placeholder="john@example.com"
            />
          </div>
          <div>
            <label for="subject" class="block text-gray-300 text-sm font-medium mb-2">Subject</label>
            <select
              id="subject"
              name="subject"
              class="w-full px-4 py-3 rounded-lg bg-[#0D0D1A] border border-[#D4AF37]/20 text-white focus:outline-none focus:border-[#D4AF37] text-sm"
            >
              <option value="general">General Inquiry</option>
              <option value="feedback">Content Feedback</option>
              <option value="partnership">Partnership Opportunity</option>
              <option value="media">Media / Press</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-gray-300 text-sm font-medium mb-2">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-lg bg-[#0D0D1A] border border-[#D4AF37]/20 text-white placeholder-gray-500 focus:outline-none focus:border-[#D4AF37] text-sm resize-none"
              placeholder="How can we help you?"
            ></textarea>
          </div>
          <button type="submit" class="btn-gold w-full">
            Send Message →
          </button>
          <p class="text-gray-600 text-xs text-center">For now, please email us directly at support@mindsuccessprogram.com. We're working on making this form fully functional.</p>
        </form>
      </div>
    </div>
  </section>
</Layout>
